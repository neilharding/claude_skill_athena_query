# Default AWS profile to use for queries
ATHENA_DEFAULT_PROFILE=dev

# Comma-separated list of configured profiles
ATHENA_PROFILES=dev

# Per-profile Athena settings (replace PROFILENAME with actual profile name in uppercase)
# ATHENA_DATABASE_PROFILENAME=your_database
# ATHENA_REGION_PROFILENAME=us-east-1
# ATHENA_WORKGROUP_PROFILENAME=primary
# ATHENA_OUTPUT_LOCATION_PROFILENAME=s3://your-bucket/results/

# Example for "dev" profile:
ATHENA_DATABASE_DEV=your_database
ATHENA_REGION_DEV=us-east-1
ATHENA_WORKGROUP_DEV=primary
ATHENA_OUTPUT_LOCATION_DEV=s3://your-bucket/results/
